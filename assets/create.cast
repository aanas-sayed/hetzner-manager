[0.001, "o", "  \u001b[2m \u001b[0m\u001b[1;2;36m9\u001b[0m\u001b[2m.\u001b[0m act \u001b[1m(\u001b[0mrun GitHub Actions locally\u001b[1m)\u001b[0m  \u001b[1;2m(\u001b[0m\u001b[2mact\u001b[0m\u001b[1;2m)\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1;2;36m10\u001b[0m\u001b[2m.\u001b[0m rclone \u001b[1m(\u001b[0msync files to/from cloud storage\u001b[1m)\u001b[0m  \u001b[1;2m(\u001b[0m\u001b[2mrclone\u001b[0m\u001b[1;2m)\u001b[0m\r\n"]
