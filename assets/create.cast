[0.000, "o", "  \u001b[2m \u001b[0m\u001b[1;2;36m7\u001b[0m\u001b[2m.\u001b[0m Rust \u001b[1m(\u001b[0mvia rustup\u001b[1m)\u001b[0m  \u001b[1;2m(\u001b[0m\u001b[2mrust\u001b[0m\u001b[1;2m)\u001b[0m\r\n"]
